rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isWorkLogOwner(worklog) {
      return isAuthenticated() && 
        (worklog.employeeId == request.auth.uid || 
         worklog.createdBy == request.auth.uid);
    }
    
    function isNotLocked(worklog) {
      return worklog.locked != true;
    }
    
    function isValidWorkLog() {
      return request.resource.data.keys().hasAll(['date', 'time', 'minorTask', 'mainDuty']) &&
             request.resource.data.date is string &&
             request.resource.data.time is string &&
             request.resource.data.minorTask is string &&
             request.resource.data.mainDuty is string;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      // Users can update their own profile (except role)
      allow update: if isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nickname', 'fullName']);
    }

    // Worklogs collection
    match /worklogs/{worklogId} {
      // Read: Admin sees all, users see their own
      allow read: if isAdmin() || 
        (isAuthenticated() && resource.data.employeeId == request.auth.uid);
      
      // Create: Any authenticated user can create
      allow create: if isAuthenticated() && isValidWorkLog();
      
      // Update: Admin or owner (if not locked)
      allow update: if isAdmin() || 
        (isWorkLogOwner(resource.data) && isNotLocked(resource.data) && isValidWorkLog());
      
      // Delete: Admin or owner (if not locked)
      allow delete: if isAdmin() || 
        (isWorkLogOwner(resource.data) && isNotLocked(resource.data));
    }

    // Audit logs collection
    match /auditLogs/{logId} {
      // Only admin can read audit logs
      allow read: if isAdmin();
      
      // System only (via Cloud Functions)
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Categories collection (read-only for users)
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Settings collection (admin only)
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
