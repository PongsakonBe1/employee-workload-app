rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }
    
    // Check if authenticated user can create their own user document (first time login)
    function canCreateOwnUser(userId) {
      return isAuthenticated() && 
        request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isStaff() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }
    
    function isWorkLogOwner(worklog) {
      return isAuthenticated() && 
        (worklog.employeeId == request.auth.uid || 
         worklog.createdBy == request.auth.uid);
    }
    
    function isNotLocked(worklog) {
      return worklog.locked != true;
    }
    
    function isValidWorkLog() {
      return request.resource.data.keys().hasAll(['date', 'time', 'minorTask', 'mainDuty']) &&
             request.resource.data.date is string &&
             request.resource.data.time is string &&
             request.resource.data.minorTask is string &&
             request.resource.data.mainDuty is string;
    }

    function isValidWorkLogUpdate() {
      // Update ไม่จำเป็นต้องส่งทุกฟิลด์ — ตรวจเฉพาะฟิลด์ที่ส่งมาว่าถูกชนิด
      let hasDate = request.resource.data.keys().hasAny(['date']);
      let hasTime = request.resource.data.keys().hasAny(['time']);
      let validDate = !hasDate || (request.resource.data.date is string);
      let validTime = !hasTime || (request.resource.data.time is string);
      return validDate && validTime;
    }

    function isSameDay(worklog) {
      // ตรวจสอบว่า worklog date ตรงกับวันนี้ (YYYY-MM-DD)
      // request.time is Timestamp; extract year/month/day and format as YYYY-MM-DD
      let requestDate = request.time;
      let year = requestDate.year();
      let month = requestDate.month();
      let day = requestDate.day();
      // Zero-pad month and day
      let monthStr = month < 10 ? "0" + month : "" + month;
      let dayStr = day < 10 ? "0" + day : "" + day;
      let dateStr = year + "-" + monthStr + "-" + dayStr;
      return worklog.date == dateStr;
    }

    // Users collection
    match /users/{userId} {
      // Allow all authenticated users to read
      allow read: if isAuthenticated();
      
      // Allow authenticated user to create their own document
      // Case 1: Without role (first time login, role set later by system)
      // Case 2: With role 'superadmin' only for specific whitelisted emails
      // Case 3: Admin/Superadmin can create users for others (for approval system)
      allow create: if 
        // กรณีสร้างให้ตัวเอง
        (canCreateOwnUser(userId) &&
          (
            !request.resource.data.keys().hasAny(['role'])
            ||
            (request.resource.data.role == 'superadmin' &&
             request.resource.data.email in ['pongsagon.be1@gmail.com', 'pongsakon.be1@gmail.com'])
            ||
            request.resource.data.role == 'staff'
          )
        )
        ||
        // กรณี Admin/Superadmin สร้างให้คนอื่น (อนุมัติ user)
        (isAdmin() && request.resource.data.role in ['admin', 'staff']);
      
      // Superadmin can update/delete any user and set any role
      allow update, delete: if isSuperAdmin();
      
      // Admin can update users (but cannot create superadmin or update other admins)
      allow update: if isAdmin() && 
        request.resource.data.role != 'superadmin' &&
        !(resource.data.role == 'admin' && request.auth.uid != userId);
      
      // Users can update their own profile (except role)
      // SA Note: fcmToken อนุญาติให้ user บันทึก token สำหรับ push notification
      allow update: if isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nickname', 'fullName', 'displayName', 'lastLoginAt', 'fcmToken']);
    }

    // Worklogs collection
    match /worklogs/{worklogId} {
      // Read: All authenticated users (filter at client level)
      // Temporary fix: isAdmin() causes circular dependency issues
      allow read: if isAuthenticated();
      
      // Create: Staff can only create their own worklog, Admin can create for anyone
      allow create: if isAuthenticated() && isValidWorkLog() &&
        (request.resource.data.employeeId == request.auth.uid || isAdmin());
      
      // Update: Admin anytime (with validation), staff/owner only same-day and if not locked
      allow update: if (isAdmin() && isValidWorkLogUpdate()) ||
        (isAuthenticated() &&
         (resource.data.employeeId == request.auth.uid || resource.data.createdBy == request.auth.uid) &&
         resource.data.locked != true &&
         isSameDay(resource.data) &&
         isValidWorkLogUpdate());
      
      // Delete: Admin anytime, staff/owner only same-day and if not locked
      allow delete: if isAdmin() ||
         (isAuthenticated() && 
          (resource.data.employeeId == request.auth.uid || resource.data.createdBy == request.auth.uid) &&
          resource.data.locked != true &&
          isSameDay(resource.data));
    }

    // Audit logs collection
    match /auditLogs/{logId} {
      // Only admin can read audit logs
      allow read: if isAdmin();
      
      // System only (via Cloud Functions)
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Categories collection (read-only for users)
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Settings collection (admin only)
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Pending users collection (for approval system)
    match /pendingUsers/{userId} {
      // Admin can read all pending users
      allow read: if isAdmin();
      
      // Authenticated users can create their own pending request
      allow create: if isAuthenticated() && 
        request.auth.uid == userId &&
        request.resource.data.email.matches('.*@icit\\.kmutnb\\.ac\\.th');
      
      // Admin can delete (approve/reject)
      allow delete: if isAdmin();
      
      // No updates allowed
      allow update: if false;
    }

    // Notifications collection
    match /notifications/{notificationId} {
      // get: Users can read their own notifications + broadcast to all + role-based
      allow get: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || 
         resource.data.userId == "all" ||
         resource.data.userId == "staff" && isStaff() ||
         resource.data.userId == "admin" && isAdmin() ||
         resource.data.userId == "superadmin" && isSuperAdmin());
      
      // list: Allow all authenticated to list (filter at client side for quota optimization)
      allow list: if isAuthenticated();
      
      // System/Admin/Superadmin can create notifications, or users creating personal notifications
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      
      // Users can update (mark as read) their own + broadcast + role-based notifications
      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || 
         resource.data.userId == "all" ||
         (resource.data.userId == "staff" && isStaff()) ||
         (resource.data.userId == "admin" && isAdmin()) ||
         isSuperAdmin()) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt', 'readBy']);
      
      // Users can delete their own + broadcast + role-based notifications, superadmin can delete any
      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || 
         resource.data.userId == "all" ||
         (resource.data.userId == "staff" && isStaff()) ||
         (resource.data.userId == "admin" && isAdmin()) ||
         isSuperAdmin());
    }

    // Admin Promotion Requests collection
    match /adminPromotionRequests/{requestId} {
      // Superadmin can read all requests
      // Admin can read their own requests
      allow read: if isAuthenticated() && 
        (isSuperAdmin() || resource.data.requestedBy == request.auth.uid);
      
      // Admin can create requests
      allow create: if isAuthenticated() && 
        isAdmin() && 
        request.resource.data.requestedBy == request.auth.uid &&
        request.resource.data.status == 'pending';
      
      // Superadmin can update (approve/reject) requests
      allow update: if isAuthenticated() && 
        isSuperAdmin() &&
        request.resource.data.status in ['approved', 'rejected'];
      
      // Superadmin can delete requests
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // Export Requests collection (for staff export approval workflow)
    match /exportRequests/{requestId} {
      // Staff can read their own requests (check resource.data for single doc)
      // Admin/Superadmin can read all requests
      // Note: For list queries, staff must filter client-side
      allow get: if isAuthenticated() && 
        (resource.data.staffId == request.auth.uid || isAdmin());
      
      // Staff can list all but will filter client-side (simpler for rules)
      // Alternative: Only allow admin to list, staff must use specific doc ID
      allow list: if isAuthenticated() && isAdmin();
      
      // Staff can create their own requests (simplified - trust client)
      allow create: if isAuthenticated();
      
      // Admin/Superadmin can update (approve/reject) any request
      allow update: if isAuthenticated() && 
        isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'approvedAt', 'approvedBy', 'approvedByName', 'rejectedAt', 'rejectedBy', 'rejectedByName']);
      
      // Admin/Superadmin can delete requests
      allow delete: if isAuthenticated() && isAdmin();
    }

    // System Logs collection (for superadmin audit)
    match /systemLogs/{logId} {
      // Only superadmin can read system logs
      allow read: if isSuperAdmin();
      
      // Any authenticated user can create logs (needed for login/logout events)
      allow create: if isAuthenticated();
      
      // No updates/deletes
      allow update, delete: if false;
    }

    // Global Templates collection (Quick Log Templates)
    match /globalTemplates/{templateId} {
      // All authenticated users can read templates
      allow read: if isAuthenticated();
      
      // Admin and superadmin can create templates
      allow create: if isAdmin() && 
        request.resource.data.keys().hasAll(['name', 'minorTask', 'mainDuty']) &&
        request.resource.data.name is string &&
        request.resource.data.minorTask is string &&
        request.resource.data.mainDuty is string;
      
      // Admin can update all fields; authenticated users can only update usage stats
      allow update: if isAdmin() ||
        (isAuthenticated() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount', 'lastUsedAt']));
      
      // Admin and superadmin can delete templates
      allow delete: if isAdmin();
    }

    // RoomEquipmentStatus collection (for tracking room and equipment status)
    match /RoomEquipmentStatus/{statusId} {
      // All authenticated users can read status
      allow read: if isAuthenticated();
      
      // Staff and admin can update status (for borrowing/returning equipment, opening/closing rooms)
      allow update: if isAuthenticated() && (isStaff() || isAdmin());
      
      // Only admin can create/delete status documents
      allow create, delete: if isAdmin();
    }
  }
}
