NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://localhost:27017/icit_workload
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_ORIGIN=http://localhost:3000

# Firebase Admin SDK (Push Notification)
# คัดลอกทั้งหมดจากไฟล์ service-account.json มาใส่ในบรรทัดเดียว
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Cron Job Secret (สำหรับยืนยัน request จาก cron-job.org)
CRON_SECRET=replace-with-a-long-random-secret-at-least-32-chars
