{
  "name": "icit-workload-recorder",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "seed": "npm run seed --workspace backend",
    "lint": "npm run lint --workspace frontend",
    "start:backend": "npm start --workspace backend",
    "start:frontend": "npm start --workspace frontend",
    "pre-build-check": "node pre-build-check.js",
    "copy-env": "copy frontend\\.env.production frontend\\.env.local /y",
    "test:gray-box": "npm run pre-build-check && npm run copy-env && cd frontend && npx playwright test --project=chromium",
    "build:prod": "npm run pre-build-check && npm run copy-env && cd frontend && npm run build",
    "deploy:firebase": "cd firebase && firebase deploy --only hosting",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "tslib": "^2.8.1"
  }
}
